{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/stop-hook-git-check.sh"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": ["Skill"]
    },
    "mcpServers": {
        "render": {
            "command": "npx",
            "args": ["-y", "@render-oss/render-mcp-server"],
            "env": {
                "RENDER_API_KEY": "YOUR_RENDER_API_KEY"
            }
        }
    }
}
