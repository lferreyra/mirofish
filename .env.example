# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 멀티 계정 설정 (선택사항, 최대 20개) =====
# Rate limit 도달 시 자동으로 다음 계정으로 전환됩니다.
# Thinking level: off / minimal / low / medium / high / xhigh
# xhigh는 o3, o4-mini, claude-opus-4-6 등 지원 모델에서만 사용 가능

# 방법 1: JSON 형식 (한 줄에 모든 계정 정의)
# LLM_ACCOUNTS='[{"name":"primary","auth_type":"api_key","api_key":"sk-...","base_url":"https://api.openai.com/v1","model":"o3","priority":0,"default_thinking":"high","max_thinking_budget":20000}]'

# 방법 2: 번호 기반 (더 읽기 쉬움)

# --- 계정 1: OpenAI API Key (thinking: xhigh) ---
# LLM_ACCOUNT_1_NAME=openai-primary
# LLM_ACCOUNT_1_AUTH_TYPE=api_key
# LLM_ACCOUNT_1_API_KEY=sk-your-primary-key
# LLM_ACCOUNT_1_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_1_MODEL=o3
# LLM_ACCOUNT_1_PRIORITY=0
# LLM_ACCOUNT_1_DEFAULT_THINKING=xhigh
# LLM_ACCOUNT_1_MAX_THINKING_BUDGET=30000

# --- 계정 2: Codex OAuth (thinking: high) ---
# LLM_ACCOUNT_2_NAME=codex-oauth-1
# LLM_ACCOUNT_2_AUTH_TYPE=oauth
# LLM_ACCOUNT_2_CLIENT_ID=your_client_id
# LLM_ACCOUNT_2_CLIENT_SECRET=your_client_secret
# LLM_ACCOUNT_2_TOKEN_URL=https://auth.example.com/oauth/token
# LLM_ACCOUNT_2_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_2_MODEL=o4-mini
# LLM_ACCOUNT_2_PRIORITY=1
# LLM_ACCOUNT_2_OAUTH_SCOPE=openai.api
# LLM_ACCOUNT_2_DEFAULT_THINKING=high
# LLM_ACCOUNT_2_MAX_THINKING_BUDGET=20000

# --- 계정 3: Codex OAuth 2번째 ---
# LLM_ACCOUNT_3_NAME=codex-oauth-2
# LLM_ACCOUNT_3_AUTH_TYPE=oauth
# LLM_ACCOUNT_3_CLIENT_ID=your_client_id_2
# LLM_ACCOUNT_3_CLIENT_SECRET=your_client_secret_2
# LLM_ACCOUNT_3_TOKEN_URL=https://auth.example.com/oauth/token
# LLM_ACCOUNT_3_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_3_MODEL=o4-mini
# LLM_ACCOUNT_3_PRIORITY=2
# LLM_ACCOUNT_3_DEFAULT_THINKING=high

# --- 계정 4: Anthropic API Key (thinking: high) ---
# LLM_ACCOUNT_4_NAME=anthropic-claude
# LLM_ACCOUNT_4_AUTH_TYPE=api_key
# LLM_ACCOUNT_4_API_KEY=sk-ant-your-key
# LLM_ACCOUNT_4_BASE_URL=https://api.anthropic.com/v1
# LLM_ACCOUNT_4_MODEL=claude-sonnet-4-6
# LLM_ACCOUNT_4_PRIORITY=3
# LLM_ACCOUNT_4_DEFAULT_THINKING=high
# LLM_ACCOUNT_4_MAX_THINKING_BUDGET=15000

# --- 계정 5: 백업 (no thinking, 저비용) ---
# LLM_ACCOUNT_5_NAME=backup-qwen
# LLM_ACCOUNT_5_AUTH_TYPE=api_key
# LLM_ACCOUNT_5_API_KEY=sk-your-backup-key
# LLM_ACCOUNT_5_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_ACCOUNT_5_MODEL=qwen-plus
# LLM_ACCOUNT_5_PRIORITY=4