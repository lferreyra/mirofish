# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 默认示例使用 OpenRouter 免费模型
# 模型: arcee-ai/trinity-large-preview:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=arcee-ai/trinity-large-preview:free
LLM_REQUEST_TIMEOUT_SECONDS=300
LLM_JSON_RETRY_ATTEMPTS=3
ONTOLOGY_LLM_TIMEOUT_SECONDS=300
ONTOLOGY_LLM_RETRY_ATTEMPTS=3
ONTOLOGY_LLM_MAX_TOKENS=8192

# 首次附件解析专用模型（可选）
# 仅用于初始上传文件的读取；如果不配置，会自动回退到上面的 LLM_* 配置
# INPUT_LLM_API_KEY=your_input_llm_api_key_here
# INPUT_LLM_BASE_URL=https://openrouter.ai/api/v1
# INPUT_LLM_MODEL_NAME=openai/gpt-4.1-mini

# OpenRouter 多 Key 轮询（推荐）
# 请求会按 key1 -> key2 -> ... -> key6 做 round-robin；
# 当前请求失败且命中 401/402/429/5xx/部分403(鉴权类) 或 credit/rate limit 错误时，会自动切到下一个 key 重试
OPENROUTER_API_KEY1=your_openrouter_api_key_1
OPENROUTER_API_KEY2=your_openrouter_api_key_2
OPENROUTER_API_KEY3=your_openrouter_api_key_3
OPENROUTER_API_KEY4=your_openrouter_api_key_4
OPENROUTER_API_KEY5=your_openrouter_api_key_5
OPENROUTER_API_KEY6=your_openrouter_api_key_6

# 单 Key 兼容模式（可选）
# 如果没有配置 OPENROUTER_API_KEY1..N，才会回退使用 LLM_API_KEY
# LLM_API_KEY=your_openrouter_api_key_here

# 注意：
# backend 当前只会自动读取项目根目录 .env，不会自动读取 .env.openrouter
# 如果要启用 INPUT_LLM_*，请写入 .env

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
# 如已使用上面的 OpenRouter 多 Key 池，可只配置下面的 BASE_URL / MODEL；
# 此时 boost 会自动复用同一组 OPENROUTER_API_KEY1..N，但按反向顺序选择起始 key
# 若想强制指定单独 key，再填写 LLM_BOOST_API_KEY
# LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Frontend 超时配置（可选，Vite 环境变量）=====
# 仅用于 /api/graph/ontology/generate；未配置时默认 960000ms（16分钟）
# VITE_ONTOLOGY_HTTP_TIMEOUT_MS=960000
