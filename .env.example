# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 외부 실시간 데이터 설정 (선택사항) =====
# 여러 API를 fallback chain으로 사용 — 하나 quota 소진 시 자동 전환
# 전부 없어도 시뮬레이션은 정상 동작 (내부 데이터만 사용)
EXTERNAL_DATA_ENABLED=true

# 웹 검색 API (Brave → Tavily → SerpAPI fallback)
# BRAVE_SEARCH_API_KEY=your_brave_key
# TAVILY_API_KEY=your_tavily_key
# SERP_API_KEY=your_serp_key

# 뉴스 API (NewsAPI → Google News RSS fallback)
# NEWS_API_KEY=your_newsapi_key

# 시장/금융 데이터 (Alpha Vantage → Yahoo Finance fallback)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# 시뮬레이션 중 외부 데이터 주입 간격 (라운드 단위, 기본 10)
# EXTERNAL_DATA_INJECT_INTERVAL=10

# ===== 멀티 계정 설정 (선택사항, 최대 20개) =====
# Rate limit 도달 시 자동으로 다음 계정으로 전환됩니다.
# Thinking level: off / minimal / low / medium / high / xhigh
# xhigh는 o3, o4-mini, claude-opus-4-6 등 지원 모델에서만 사용 가능

# 방법 1: JSON 형식 (한 줄에 모든 계정 정의)
# LLM_ACCOUNTS='[{"name":"codex-1","auth_type":"oauth","client_id":"...","client_secret":"...","token_url":"...","base_url":"https://api.openai.com/v1","model":"gpt-5.4","priority":0,"default_thinking":"high"}]'

# 방법 2: 번호 기반 (더 읽기 쉬움)
# 장기 실행 task 지원: 모든 계정이 rate limit에 걸려도 cooldown 대기 후 자동 재시도
# Codex 5h rolling / 1week rolling limit에 맞게 수 시간 대기 가능

# --- 계정 1: Codex OAuth (GPT-5.4, primary) ---
# LLM_ACCOUNT_1_NAME=codex-primary
# LLM_ACCOUNT_1_AUTH_TYPE=oauth
# LLM_ACCOUNT_1_CLIENT_ID=your_client_id_1
# LLM_ACCOUNT_1_CLIENT_SECRET=your_client_secret_1
# LLM_ACCOUNT_1_TOKEN_URL=https://auth.openai.com/oauth/token
# LLM_ACCOUNT_1_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_1_MODEL=gpt-5.4
# LLM_ACCOUNT_1_PRIORITY=0
# LLM_ACCOUNT_1_DEFAULT_THINKING=high
# LLM_ACCOUNT_1_MAX_THINKING_BUDGET=30000

# --- 계정 2: Codex OAuth (GPT-5.4) ---
# LLM_ACCOUNT_2_NAME=codex-secondary
# LLM_ACCOUNT_2_AUTH_TYPE=oauth
# LLM_ACCOUNT_2_CLIENT_ID=your_client_id_2
# LLM_ACCOUNT_2_CLIENT_SECRET=your_client_secret_2
# LLM_ACCOUNT_2_TOKEN_URL=https://auth.openai.com/oauth/token
# LLM_ACCOUNT_2_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_2_MODEL=gpt-5.4
# LLM_ACCOUNT_2_PRIORITY=1
# LLM_ACCOUNT_2_DEFAULT_THINKING=high

# --- 계정 3: Codex OAuth (GPT-5.4) ---
# LLM_ACCOUNT_3_NAME=codex-tertiary
# LLM_ACCOUNT_3_AUTH_TYPE=oauth
# LLM_ACCOUNT_3_CLIENT_ID=your_client_id_3
# LLM_ACCOUNT_3_CLIENT_SECRET=your_client_secret_3
# LLM_ACCOUNT_3_TOKEN_URL=https://auth.openai.com/oauth/token
# LLM_ACCOUNT_3_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_3_MODEL=gpt-5.4
# LLM_ACCOUNT_3_PRIORITY=2
# LLM_ACCOUNT_3_DEFAULT_THINKING=high

# --- 계정 4: Codex OAuth (GPT-5.4-mini, 경량) ---
# LLM_ACCOUNT_4_NAME=codex-mini
# LLM_ACCOUNT_4_AUTH_TYPE=oauth
# LLM_ACCOUNT_4_CLIENT_ID=your_client_id_4
# LLM_ACCOUNT_4_CLIENT_SECRET=your_client_secret_4
# LLM_ACCOUNT_4_TOKEN_URL=https://auth.openai.com/oauth/token
# LLM_ACCOUNT_4_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_4_MODEL=gpt-5.4-mini
# LLM_ACCOUNT_4_PRIORITY=3
# LLM_ACCOUNT_4_DEFAULT_THINKING=high

# --- 계정 5: Codex OAuth (GPT-5.4, 예비) ---
# LLM_ACCOUNT_5_NAME=codex-reserve
# LLM_ACCOUNT_5_AUTH_TYPE=oauth
# LLM_ACCOUNT_5_CLIENT_ID=your_client_id_5
# LLM_ACCOUNT_5_CLIENT_SECRET=your_client_secret_5
# LLM_ACCOUNT_5_TOKEN_URL=https://auth.openai.com/oauth/token
# LLM_ACCOUNT_5_BASE_URL=https://api.openai.com/v1
# LLM_ACCOUNT_5_MODEL=gpt-5.4
# LLM_ACCOUNT_5_PRIORITY=4
# LLM_ACCOUNT_5_DEFAULT_THINKING=high