# ===== LLM API Configuration (OpenAI SDK compatible) =====
# Recommended: Alibaba Bailian qwen-plus: https://bailian.console.aliyun.com/
# Note: High consumption, try simulations with <40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# LLM timeout and retry settings
# LLM_TIMEOUT=120
# LLM_MAX_RETRIES=3

# ===== Zep Memory Graph Configuration =====
# Free monthly quota for simple usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM Configuration (optional) =====
# Only add these if using a separate accelerated LLM
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Security Configuration =====
# Generate a strong secret key: python3 -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# Enable debug mode (default: False in production)
FLASK_DEBUG=True

# API authentication (optional, disabled when not set)
# Set this to require Bearer token auth on all /api/* endpoints
# MIROFISH_API_KEY=

# CORS allowed origins (comma-separated, default: * for local dev)
# CORS_ORIGINS=http://localhost:3000
