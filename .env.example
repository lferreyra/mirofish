# LLM API config (supports any OpenAI SDK-compatible LLM API)
# Recommended: Alibaba Bailian platform with qwen-plus model: https://bailian.console.aliyun.com/
# Note: token consumption can be high — start with fewer than 40 simulation rounds
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep Graph Memory config =====
# Free monthly quota is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM config (optional) =====
# If not using boost config, remove these entries from your .env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Lite Mode (optional) =====
# Set to true to skip Zep Cloud dependency (graph/simulation features disabled)
# LITE_MODE=true

# ===== Claude Code Bridge Mode (recommended for local dev) =====
# Use Claude via Claude Code CLI (requires Max subscription plan)
# No API key needed — uses Claude CLI directly
# Launch: bash start.sh or npm run dev:bridge
# LLM_BASE_URL=http://localhost:8082/v1
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=claude-sonnet-4-6
