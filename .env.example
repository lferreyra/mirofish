# =============================================================================
# ⚡️ CLOUD DEPLOYMENT QUICKSTART
# =============================================================================
# Copy this file to `.env`, fill in the three SECRET lines marked below, and
# you have a working production config. Everything else can stay at defaults.
#
# Single-vendor OpenAI preset (simplest; one bill, one key):
#   1) Replace sk-REPLACE-ME with your OpenAI key
#   2) Replace CHANGE-ME-ADMIN-TOKEN with `openssl rand -hex 32`
#   3) If using Neo4j AuraDB, fill in NEO4J_URI + NEO4J_PASSWORD below
#
# For multi-vendor setups (Anthropic Haiku+Opus + OpenAI embed + Aura), see
# the per-role LLM_ROLE_* and Phase-4/6 sections further down.
# =============================================================================

# =============================================================================
# Backend mode
# =============================================================================
# local  -> All roles use a local Ollama server. Requires Ollama running and the
#           default models (qwen2.5:3b/7b/14b, nomic-embed-text) pulled.
#           No cloud API keys needed.
# cloud  -> Per-role cloud config (LLM_ROLE_*_*). Falls back to the legacy
#           LLM_API_KEY/LLM_BASE_URL/LLM_MODEL_NAME for unset roles.
# custom -> Pure per-role config; legacy keys are NOT used as defaults.
BACKEND_MODE=cloud

# Flask — bind 0.0.0.0 in cloud so containers / load balancers can reach it.
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=false

# =============================================================================
# Default LLM (single-vendor fallback for every role)
# =============================================================================
# Used whenever a role does NOT have its own LLM_ROLE_<role>_* key.
# Defaults here are OpenAI — simplest cloud path (one vendor, one bill,
# built-in price table, works for both chat and embeddings).
#
# Alternative: set to Aliyun DashScope qwen-plus (upstream default) —
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL_NAME=qwen-plus
LLM_API_KEY=sk-REPLACE-ME
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# -----------------------------------------------------------------------------
# Promote the `heavy` role (ReportAgent synthesis) to a stronger model — cheap
# to keep everything else on mini, since heavy runs only once per simulation.
# Comment these out to run 100% on gpt-4o-mini.
# -----------------------------------------------------------------------------
LLM_ROLE_HEAVY_BACKEND=openai_compat
LLM_ROLE_HEAVY_PROVIDER=openai
LLM_ROLE_HEAVY_MODEL=gpt-4o
# LLM_ROLE_HEAVY_API_KEY inherits from LLM_API_KEY when unset

# Dedicated embedding model — OpenAI's text-embedding-3-large.
LLM_ROLE_EMBED_BACKEND=openai_compat
LLM_ROLE_EMBED_PROVIDER=openai
LLM_ROLE_EMBED_MODEL=text-embedding-3-large

# =============================================================================
# Per-role cloud routing (Phase 1)
# =============================================================================
# Each task role can be pinned to a different backend / provider / model.
# Roles:
#   fast      -> NER, agent actions, routine decisions
#   balanced  -> post / comment generation
#   heavy     -> ReportAgent synthesis
#   embed     -> vector embeddings
#
# Backend kinds: openai_compat | ollama | vllm
# Providers (openai_compat): openai | anthropic | together | deepinfra | groq |
#                            fireworks | generic
#
# Example cloud setup (Anthropic Haiku for fast, Opus for heavy):
# LLM_ROLE_FAST_BACKEND=openai_compat
# LLM_ROLE_FAST_PROVIDER=anthropic
# LLM_ROLE_FAST_MODEL=claude-haiku-4-5-20251001
# LLM_ROLE_FAST_API_KEY=sk-ant-...
# LLM_ROLE_FAST_BASE_URL=https://api.anthropic.com/v1
#
# LLM_ROLE_HEAVY_BACKEND=openai_compat
# LLM_ROLE_HEAVY_PROVIDER=anthropic
# LLM_ROLE_HEAVY_MODEL=claude-opus-4-7
# LLM_ROLE_HEAVY_API_KEY=sk-ant-...
# LLM_ROLE_HEAVY_BASE_URL=https://api.anthropic.com/v1
#
# LLM_ROLE_EMBED_BACKEND=openai_compat
# LLM_ROLE_EMBED_PROVIDER=openai
# LLM_ROLE_EMBED_MODEL=text-embedding-3-large
# LLM_ROLE_EMBED_API_KEY=sk-...
#
# Comma-separated fallback chain (other role names). On exhaustion of retries
# for the primary backend, the router tries the next role's backend in order:
# LLM_ROLE_HEAVY_FALLBACKS=balanced,fast

# Retry budget per backend before falling through the chain (default 3).
LLM_MAX_RETRIES=3

# Path to the SQLite DB that stores per-call token / latency / cost.
# Default: <repo>/backend/data/llm_calls.db
# LLM_CALLS_DB=

# Optional: JSON file overriding the built-in pricing table for cost estimation.
# Format: [{"provider":"openai","model":"gpt-4o","input_per_mtok":2.5,
#           "output_per_mtok":10.0,"cached_input_per_mtok":1.25}, ...]
# LLM_PRICING_JSON=

# =============================================================================
# Local Ollama (used when BACKEND_MODE=local or LLM_ROLE_*_BACKEND=ollama)
# =============================================================================
# OLLAMA_BASE_URL=http://localhost:11434
# Default models per role (override via LLM_ROLE_<role>_MODEL):
#   fast=qwen2.5:3b  balanced=qwen2.5:7b  heavy=qwen2.5:14b  embed=nomic-embed-text

# =============================================================================
# Self-hosted vLLM (used when LLM_ROLE_*_BACKEND=vllm)
# =============================================================================
# vLLM exposes an OpenAI-compatible HTTP server. These flags must match how the
# server was launched — the client cannot toggle them per-request.
# VLLM_BASE_URL=http://vllm.internal:8000/v1
# VLLM_API_KEY=EMPTY
# VLLM_DRAFT_MODEL=meta-llama/Llama-3.2-1B-Instruct
# VLLM_SPECULATIVE_TOKENS=4

# =============================================================================
# Memory backend (Phase 2)
# =============================================================================
# Selects the agent-memory store (observations, reflections, contradiction edges).
#
#   auto        -> pick based on what's set: NEO4J_URI > ZEP_API_KEY > in_memory
#   in_memory   -> per-process dict; zero external deps. Tests / minimal local runs.
#   zep_cloud   -> managed Zep (this is what upstream MiroFish uses today)
#   neo4j_local -> self-hosted Neo4j 5.x via bolt://
#   neo4j_aura  -> managed Neo4j AuraDB via neo4j+s://
MEMORY_BACKEND=auto

# Neo4j AuraDB (recommended for cloud deployments) — fill these in and the
# `auto` setting above will pick neo4j_aura automatically:
# NEO4J_URI=neo4j+s://xxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=REPLACE-ME
# NEO4J_DATABASE=neo4j

# Self-hosted Neo4j alternative:
# NEO4J_URI=bolt://neo4j-host:7687

# Zep memory graph — still required by the upstream graph-builder path even
# when MEMORY_BACKEND is neo4j_*. Free tier covers light usage:
# https://app.getzep.com/.  Leave as a literal placeholder only if you plan
# to disable the Zep graph-builder path explicitly (advanced).
ZEP_API_KEY=zk-REPLACE-ME

# =============================================================================
# Hierarchical memory (Phase 2)
# =============================================================================
# Stanford Generative Agents pattern:
#   - every agent action is scored 1-10 for `importance` at write time (fast LLM)
#   - every N rounds, top-K observations are synthesized into 3-5 reflections (balanced LLM)
#   - nearest neighbors of each new observation are checked for contradiction (fast LLM)
#
# Reflection cadence (rounds). Smaller = more reflections = more LLM spend.
REFLECTION_EVERY_N_ROUNDS=5
REFLECTION_TOP_K_SOURCES=10

# Retrieval scoring weights: score = α·recency + β·importance + γ·relevance
# Backend normalizes (α,β,γ) / (α+β+γ) before combining.
MEMORY_ALPHA=1.0
MEMORY_BETA=1.0
MEMORY_GAMMA=1.0

# Feature flags — set any to `false` to isolate the contribution during ablations.
MEMORY_ENABLE_IMPORTANCE=true
MEMORY_ENABLE_REFLECTION=true
MEMORY_ENABLE_CONTRADICTION=true

# =============================================================================
# Deployment / observability / auth (Phase 6)
# =============================================================================
# API-key auth. With ALLOW_ANONYMOUS_API=true, requests without a key still
# reach non-auth endpoints; recommended only for demos.
ALLOW_ANONYMOUS_API=false
# Admin token gates /api/auth/keys endpoints — required to issue / revoke keys.
# Unset = the auth admin endpoints return 503 (makes misconfig loud).
# Generate with:  openssl rand -hex 32
ADMIN_TOKEN=CHANGE-ME-ADMIN-TOKEN

# SQLite locations for API-key + usage DBs. Defaults live under backend/data/.
# AUTH_DB_PATH=/var/lib/mirofish/auth.db
# QUOTA_DB_PATH=/var/lib/mirofish/auth_usage.db

# OpenTelemetry. Empty = tracing disabled; point at an OTLP/HTTP collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=mirofish-backend
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1

# Cost budget overrides (per role; used by estimate-cost endpoint).
# Defaults are tuned against observed qwen-plus runs; override if your model
# has a different per-call token profile.
# COST_BUDGET_FAST_CALLS=1.0
# COST_BUDGET_FAST_IN=400
# COST_BUDGET_FAST_OUT=80
# COST_BUDGET_FAST_CACHED=0.5
# (repeat for BALANCED, HEAVY, EMBED)

# =============================================================================
# Persona dynamics (Phase 4)
# =============================================================================
# Agents carry structured personas (Big Five + conviction + credibility + stance).
# The population mix below determines what fraction of agents are adversarial
# or institutional archetypes.
#
# ⚠️  Enabling BOT or TROLL percentages changes simulation outcomes. Document
#    any nonzero setting in your eval run notes.
BOT_POPULATION_PCT=0
TROLL_POPULATION_PCT=0

# Institutional boosts — these raise baseline credibility for some fraction of
# agents. Safe to enable; doesn't distort conclusions.
MEDIA_POPULATION_PCT=0
EXPERT_POPULATION_PCT=0

# Seed for deterministic population mixing. Unset = nondeterministic.
# POPULATION_SEED=1234

# Credibility-weighted retrieval strength. 0.0 disables the re-rank; 1.0 makes
# high-credibility posts (institutions / experts) punch ~1.5x harder and
# low-credibility posts (rando accounts) ~0.5x.
CREDIBILITY_WEIGHT=1.0

# =============================================================================
# IPC transport (Phase 3)
# =============================================================================
# Replaces the original file-poll IPC with ZeroMQ (DEALER/ROUTER for commands,
# PUB/SUB for events) and exposes a WebSocket bridge to the frontend.
#
#   zmq  -> ZeroMQ sockets. Interview latency ~5-20ms. Default for new runs.
#   file -> legacy file-poll. No event channel. Kept for back-compat.
IPC_TRANSPORT=zmq

# Override the ipc:// socket paths (unset = auto under <simulation_dir>/.sockets).
# Use TCP (tcp://host:5555) only if backend and subprocess live on different hosts.
# IPC_CMD_ENDPOINT=tcp://127.0.0.1:5555
# IPC_EVENT_ENDPOINT=tcp://127.0.0.1:5556

# =============================================================================
# (Deprecated) Legacy boost LLM keys
# =============================================================================
# These were the upstream's optional "accelerated LLM" keys. Replaced by
# per-role config above. If unused, leave commented out.
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=
